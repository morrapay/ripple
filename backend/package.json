{
  "name": "@ripple/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "tsx --watch src/api-stub/index.ts",
    "dev": "WATCHPACK_WATCHER_LIMIT=20 next dev --hostname 127.0.0.1 -p 3005",
    "build:next": "prisma generate && next build",
    "start:next": "next start -H 0.0.0.0",
    "serve": "npm run build:next && npm run start:next",
    "restart": "lsof -ti :3005 | xargs kill -9 2>/dev/null; npm run start:next",
    "open": "open http://localhost:3005",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^5.22.0",
    "@ripple/shared": "*",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
